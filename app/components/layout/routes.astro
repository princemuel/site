---
import { excluded } from "@/assets/include";
import Icon from "@/components/shared/icon.astro";
import Navlink from "@/components/shared/navlink.astro";
import { getCollection } from "astro:content";

import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"nav">;

const excludedRoutes = new Set(excluded);
let routes = await getCollection("routes", (data) => !excludedRoutes.has(data.id));
routes = routes.toSorted((a, b) => a.data.order - b.data.order);
---

<nav
  aria-label="Main"
  class:list={["flex items-center justify-evenly capitalize", Astro.props.class]}
>
  {
    routes.map((r) => (
      <Navlink
        href={r.data.href}
        class:list={[
          "p-3 text-base",
          "text-slate-900 dark:text-slate-200",
          "hover:text-slate-200 dark:hover:text-slate-900",
          "hover:bg-slate-900 dark:hover:bg-slate-200",
          "focus:text-slate-200 dark:focus:text-slate-900",
          "focus:bg-slate-900 dark:focus:bg-slate-200",
          "aria-[current=page]:text-slate-200 dark:aria-[current=page]:text-slate-900",
          "aria-[current=page]:bg-slate-900 dark:aria-[current=page]:bg-slate-200",
        ]}
      >
        <Icon name={r.data.icon} class="text-2xl md:hidden" />
        <span class="sr-only md:not-sr-only">{r.data.text}</span>
      </Navlink>
    ))
  }
</nav>
