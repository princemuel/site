---
// SPDX-License-Identifier: Apache-2.0
import Fence from "@/components/layout/fence.astro";
import Routes from "@/components/layout/routes.astro";
import Link from "@/components/shared/link.astro";
import ThemePicker from "@/components/widgets/theme-picker.astro";

import { Icon } from "astro-icon/components";
---

<Fence as="header" class="bg-inherit">
  <section class="flex items-center justify-between">
    <Link href="/" class="self-center font-mono text-4xl">princemuel</Link>
    <ThemePicker />
  </section>

  <section class="flex items-center gap-4 border-y border-gray-200 dark:border-gray-700">
    <Routes class="mr-auto" />

    <section class="flex items-center">
      <Link
        href="/rss.xml"
        class:list={[
          "p-3 text-2xl",
          "text-gray-900 dark:text-gray-200",
          "hover:text-gray-200 dark:hover:text-gray-900",
          "hover:bg-gray-900 dark:hover:bg-gray-200",
          "focus:text-gray-200 dark:focus:text-gray-900",
          "focus:bg-gray-900 dark:focus:bg-gray-200",
        ]}
      >
        <Icon name="lucide:rss" class="text-inherit" />
        <span class="sr-only">RSS</span>
      </Link>
    </section>
  </section>
</Fence>
