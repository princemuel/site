---
type Props = {
  framework?: string;
  name?: string;
  version?: string;
  pathname?: string | URL;
};

const {
  name = "x-analytics",
  version = "0.1",
  framework = "astro",
  pathname = Astro.url.pathname,
} = Astro.props;
---

<x-analytics
  data-sdkn={name + `/${framework}`}
  data-sdkvn={version}
  data-url={pathname}
  data-is-prod={import.meta.env.PROD}></x-analytics>

<script>
  import { actions } from "astro:actions";

  import { createElement } from "@/helpers/dom";
  import { getActionPath } from "astro:actions";

  type Session = {
    id?: string;
    interactions: number;
    start: Temporal.Instant;
  };

  type EventBatchItem = {
    event: "CLICK" | "KEYDOWN" | "SCROLL";
    timestamp: string;
    metadata: string | null;
  };

  type EventType = "CLICK" | "KEYDOWN" | "SCROLL";

  createElement(
    "x-analytics",
    class Analytics extends HTMLElement {
      #controller?: AbortController;
      #session = { interactions: 0, start: Temporal.Now.instant() } as Session;
      #lastScrollTime = Temporal.Now.instant();
      #scrollThrottle = Temporal.Duration.from({ seconds: 1 });
      // Batch configuration
      #eventBatch: EventBatchItem[] = [];
      #batchSize = 10; // Send after 10 events
      #batchTimer?: number;

      async connectedCallback() {
        // if (this.dataset.isProd !== "true") return;
        this.#controller = new AbortController();

        // Initialize session with PAGE_VIEW
        try {
          const { data } = await actions.trackPageView({
            page_url: this.dataset.url ?? "",
            source_url: document.referrer,
            title: document.title,
          });

          this.#session.id = data?.session_id;
        } catch (error) {
          console.error("Analytics init failed:", error);
        }

        // Start batch timer
        this.#startBatchTimer();

        // Track events and interactions
        const signal = this.#controller.signal;
        document.addEventListener("visibilitychange", this, { signal });
        document.addEventListener("click", this, { signal });
        document.addEventListener("keydown", this, { signal });
        document.addEventListener("scroll", this, { signal, passive: true });
      }

      #startBatchTimer() {
        this.#batchTimer = window.setInterval(() => {
          this.#flushBatch();
        }, 30_000);
      }

      handleEvent<E extends Event>(event: E) {
        switch (event.type) {
          case "visibilitychange":
            this.#onVisibilityChange();
            break;
          case "click":
            this.#trackEvent("CLICK", event as unknown as MouseEvent);
            break;
          case "keydown":
            this.#trackEvent("KEYDOWN", event as unknown as KeyboardEvent);
            break;
          case "scroll":
            this.#handleScroll();
            break;
        }
      }

      #handleScroll() {
        const now = Temporal.Now.instant();
        const timeSinceLastScroll = now.since(this.#lastScrollTime);
        if (Temporal.Duration.compare(timeSinceLastScroll, this.#scrollThrottle) >= 0) {
          this.#trackEvent("SCROLL");
          this.#lastScrollTime = now;
        }

        this.#session.interactions += 1;
      }

      #trackEvent(eventType: "SCROLL"): void;
      #trackEvent(eventType: "CLICK", event?: MouseEvent): void;
      #trackEvent(eventType: "KEYDOWN", event?: KeyboardEvent): void;
      #trackEvent(eventType: EventType, event?: MouseEvent | KeyboardEvent): void {
        if (!this.#session.id) return;

        this.#session.interactions += 1;

        let metadata: Record<string, any> = {};

        if (eventType === "CLICK" && event && "target" in event) {
          const target = event.target as HTMLElement;
          metadata = {
            tag: target.tagName,
            id: target.id || null,
            // class: target.className || null,
            // text: target.textContent?.slice(0, 50) || null,
          };
        } else if (eventType === "KEYDOWN" && event && "key" in event) {
          metadata = {
            key: event.key,
            ctrl: event.ctrlKey,
            alt: event.altKey,
            shift: event.shiftKey,
          };
        } else if (eventType === "SCROLL") {
          metadata = {
            scrollY: window.scrollY,
            scrollPercent: Math.round(
              (window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100,
            ),
          };
        }

        // Add to batch
        this.#eventBatch.push({
          event: eventType,
          timestamp: Temporal.Now.instant().toString(),
          metadata: JSON.stringify(metadata),
        });

        // Flush if batch is full
        if (this.#eventBatch.length >= this.#batchSize) this.#flushBatch();
      }

      async #flushBatch() {
        if (this.#eventBatch.length === 0 || !this.#session.id) return;

        const events = [...this.#eventBatch];
        this.#eventBatch = []; // Clear batch immediately
        this.#lastBatchSent = Temporal.Now.instant();

        try {
          await actions.trackEvent({
            session_id: this.#session.id,
            page_url: this.dataset.url ?? "",
            events,
          });
        } catch (err) {
          console.error("Batch tracking failed:", err);
          // Optionally: re-add events to batch for retry
        }
      }

      #onVisibilityChange() {
        if (document.visibilityState === "hidden" && this.#session.id) {
          // Flush any pending events
          if (this.#eventBatch.length > 0) this.#flushBatchSync(); // Synchronous flush for page exit

          const end = Temporal.Now.instant();
          const duration = end.since(this.#session.start);

          // Use sendBeacon for reliability on page exit
          const data = JSON.stringify({
            session_id: this.#session.id,
            url: this.dataset.url ?? "",
            duration_ms: duration.total("milliseconds"),
            duration_human: duration.toString(),
            interactions: this.#session.interactions,
          });

          navigator.sendBeacon(
            getActionPath(actions.trackPageExit),
            new Blob([data], { type: "application/json" }),
          );
        }
      }

      #flushBatchSync() {
        if (this.#eventBatch.length === 0 || !this.#session.id) return;

        const data = JSON.stringify({
          session_id: this.#session.id,
          page_url: this.dataset.url ?? "",
          events: this.#eventBatch,
        });

        navigator.sendBeacon(
          getActionPath(actions.trackEvent),
          new Blob([data], { type: "application/json" }),
        );

        this.#eventBatch = [];
      }

      disconnectedCallback() {
        // Flush any remaining events
        this.#flushBatch();
        this.#controller?.abort();
        if (this.#batchTimer) clearInterval(this.#batchTimer);
      }
    },
  );
</script>
