    "astro": "^6.0.8",
    "http-errors-enhanced": "^4.0.2",
    "isbot": "^5.1.36",
    "outvariant": "^1.4.3",
    "resend": "^6.9.4",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "tailwind-variants": "^3.2.2",
    "temporal-polyfill": "^0.3.2"
  },
  "devDependencies": {
