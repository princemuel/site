{
  "name": "princemuelxcom",
  "type": "module",
  "version": "0.0.1",
  "description": "My personal website built with Astro, Tailwind CSS, MDX, and the Github API",
  "private": true,
  "author": "Prince Muel <68931805+princemuel@users.noreply.github.com>",
  "scripts": {
    "predev": "tsx --tsconfig ./tsconfig.scripts.json ./scripts/iconify.ts",
    "dev": "astro dev",
    "cf:generate": "wrangler types",
    "start": "wrangler types && astro dev",
    "prebuild": "tsx --tsconfig ./tsconfig.scripts.json ./scripts/iconify.ts",
    "build": "wrangler types && astro check && astro build",
    "preview": "wrangler types && astro preview",
    "astro": "astro",
    "seed:all": "tsx --tsconfig ./tsconfig.scripts.json ./src/scripts/seed.ts",
    "iconify": "tsx --tsconfig ./tsconfig.scripts.json ./scripts/iconify.ts",
    "lint": "oxlint --type-aware --type-check",
    "check": "oxlint --type-aware --type-check && astro build"
  },
  "dependencies": {
    "@repo/db": "workspace:*",
    "@repo/utils": "workspace:*",
