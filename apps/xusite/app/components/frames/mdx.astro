import Prose from "@/components/content/prose.astro";
import Shell from "@/components/frames/shell.astro";

import type { MarkdownLayoutProps } from "astro";

type PageProps = { title: string; description: string };

type Props = MarkdownLayoutProps<PageProps>;

const { frontmatter } = Astro.props;

// const { title, description } = frontmatter;
---

<Shell>
  <Prose>
    <h1 id="a11ty-headline">
      {frontmatter.title}
    </h1>
    <slot />
  </Prose>
</Shell>
